<DefaultWindow
    xmlns="https://spacestation14.io"
    Title="{Loc admin-announce-title}"
    MinWidth="760"
    MinHeight="500"
    SetSize="840 540"
    HeaderClass="DS14MenuHeader"
    TitleClass="DS14MenuTitle">
    <!-- DS14-start -->
    <PanelContainer StyleClasses="DS14MenuFlatBody">
        <BoxContainer Orientation="Vertical"
                      HorizontalExpand="True"
                      VerticalExpand="True"
                      SeparationOverride="8">
            <BoxContainer Orientation="Horizontal"
                          HorizontalExpand="True"
                          SeparationOverride="6">
                <LineEdit Name="Announcer"
                          Access="Public"
                          PlaceHolder="{Loc admin-announce-announcer-placeholder}"
                          Text="{Loc admin-announce-announcer-default}"
                          HorizontalExpand="True"
                          SizeFlagsStretchRatio="1"
                          StyleClasses="DS14MenuInput" />
                <LineEdit Name="Sender"
                          Access="Public"
                          PlaceHolder="{Loc admin-announce-sender-placeholder}"
                          Text="{Loc admin-announce-sender-default}"
                          HorizontalExpand="True"
                          SizeFlagsStretchRatio="1"
                          StyleClasses="DS14MenuInput" />
            </BoxContainer>
            <BoxContainer Orientation="Horizontal"
                          HorizontalExpand="True"
                          SeparationOverride="6">
                <BoxContainer Orientation="Horizontal"
                              HorizontalExpand="True"
                              SizeFlagsStretchRatio="1.7"
                              SeparationOverride="4">
                    <Button Name="ColorPreview"
                            Access="Public"
                            Text=" "
                            MinSize="30 28"
                            SetSize="30 28"
                            StyleClasses="DS14MenuProfileControl" />
                    <LineEdit Name="ColorHex"
                              Access="Public"
                              PlaceHolder="{Loc admin-announce-color-placeholder}"
                              Text="1d8bad"
                              HorizontalExpand="True"
                              StyleClasses="DS14MenuInput" />
                </BoxContainer>
                <LineEdit Name="SoundPath"
                          Access="Public"
                          PlaceHolder="{Loc admin-announce-sound-placeholder}"
                          Text="/Audio/_DeadSpace/Announcements/centcomm.ogg"
                          HorizontalExpand="True"
                          SizeFlagsStretchRatio="7"
                          StyleClasses="DS14MenuInput" />
                <LineEdit Name="SoundVolume"
                          Access="Public"
                          PlaceHolder="{Loc admin-announce-volume-placeholder}"
                          Text="5"
                          HorizontalExpand="True"
                          SizeFlagsStretchRatio="1.3"
                          StyleClasses="DS14MenuInput" />
            </BoxContainer>
            <PanelContainer StyleClasses="DS14MenuTextField"
                            HorizontalExpand="True"
                            VerticalExpand="True">
                <TextEdit Name="Announcement"
                          Access="Public"
                          HorizontalExpand="True"
                          VerticalExpand="True"
                          MinHeight="120"
                          StyleClasses="DS14MenuTextArea" />
            </PanelContainer>

            <BoxContainer Orientation="Vertical"
                          HorizontalExpand="True"
                          SeparationOverride="6">
                <BoxContainer Orientation="Horizontal"
                              HorizontalExpand="True"
                              SeparationOverride="6">
                    <CheckBox Name="EnableTTS"
                              Access="Public"
                              Text="{Loc admin-announce-enable-tts}"
                              Pressed="True"
                              StyleClasses="DS14MenuProfileControl" />
                    <CheckBox Name="CustomTTS"
                              Access="Public"
                              Text="{Loc admin-announce-custom-centcomm-tts}"
                              StyleClasses="DS14MenuProfileControl" />
                    <Control HorizontalExpand="True" />
                </BoxContainer>
                <BoxContainer Orientation="Horizontal"
                              HorizontalExpand="True"
                              SeparationOverride="6">
                    <OptionButton Name="VoiceSelector"
                                  Access="Public"
                                  HorizontalExpand="True"
                                  StyleClasses="DS14MenuProfileControl" />
                    <OptionButton Name="LanguageSelector"
                                  Access="Public"
                                  HorizontalExpand="True"
                                  StyleClasses="DS14MenuProfileControl" />
                </BoxContainer>
            </BoxContainer>

            <BoxContainer Orientation="Horizontal"
                          HorizontalExpand="True"
                          SeparationOverride="6"
                          MinHeight="28">
                <CheckBox Name="KeepWindowOpen"
                          Access="Public"
                          Text="{Loc admin-announce-keep-open}"
                          StyleClasses="DS14MenuProfileControl" />
                <Control HorizontalExpand="True" />
                <Button Name="AnnounceButton"
                        Access="Public"
                        Disabled="True"
                        Text="{Loc admin-announce-button}"
                        TextAlign="Center"
                        HorizontalExpand="True"
                        MinWidth="200"
                        SetHeight="26"
                        SizeFlagsStretchRatio="0.9"
                        StyleClasses="DS14MenuProfileControl" />
                <OptionButton Name="AnnounceMethod"
                              Access="Public"
                              HorizontalExpand="True"
                              MinWidth="220"
                              SetHeight="26"
                              SizeFlagsStretchRatio="1.1"
                              StyleClasses="DS14MenuProfileControl" />
            </BoxContainer>
            <PanelContainer StyleClasses="DS14MenuAccentDim"
                            SetHeight="1" />
            <Label Text="{Loc admin-announce-footer}"
                   StyleClasses="DS14MenuSubtitle"
                   ClipText="True" />
        </BoxContainer>
    </PanelContainer>
    <!-- DS14-end -->
</DefaultWindow>
